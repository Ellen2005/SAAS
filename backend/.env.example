# Copy to backend/.env and fill in your values
# ─── Supabase ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-service-role-key>
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ─── AI / Narrative ──────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_<your-groq-key>
# Optional: override default model
# GROQ_MODEL=llama-3.3-70b-versatile

# ─── Email (Brevo) ───────────────────────────────────────────────────────────
BREVO_API_KEY=xkeysib-<your-brevo-key>
EMAIL_SENDER_NAME=SAAS Analytics
EMAIL_SENDER_ADDRESS=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5000
UNSUBSCRIBE_SECRET=change-this-in-production

# ─── Feature flags ───────────────────────────────────────────────────────────
# Set to True to use synthetic data (no real DB needed for onboarding/testing)
MOCK_DATA=False
