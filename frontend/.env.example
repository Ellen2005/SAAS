# Copy to frontend/.env and fill from Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Leave empty to use Vite dev proxy (/api → http://localhost:8000)
# Or set explicitly: VITE_API_URL=http://localhost:8000
VITE_API_URL=
